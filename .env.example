# =============================================================
# OpenClaw/NemoClaw – Miljøvariabler
# Kopier denne filen til .env og fyll inn verdiene
# ALDRI legg .env i Git
# =============================================================

# --- Claude API ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Perplexity (aksjenyhet og research) ---
PERPLEXITY_API_KEY=pplx-...

# --- Microsoft Teams (Del 1: Incoming Webhook for varsler) ---
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...

# --- Microsoft Teams Bot (Del 2: to-veis kommandoer) ---
TEAMS_BOT_APP_ID=           # Azure App Registration → Application (client) ID
TEAMS_BOT_APP_PASSWORD=     # Azure App Registration → Client Secret
TEAMS_BOT_PORT=3978

# --- Gmail (OAuth2) ---
GMAIL_CLIENT_ID=...
GMAIL_CLIENT_SECRET=...
GMAIL_REFRESH_TOKEN=...

# --- Microsoft 365 / Hotmail (OAuth2) ---
MS365_CLIENT_ID=...
MS365_CLIENT_SECRET=...
MS365_TENANT_ID=...
MS365_REFRESH_TOKEN=...

# --- Lokal modell (Ollama/vLLM) ---
LOCAL_LLM_BASE_URL=http://localhost:11434
LOCAL_LLM_MODEL=qwen3:14b

# --- Portefølje ---
PORTFOLIO_SIZE_NOK=14000000
MAX_SINGLE_POSITION_PCT=15

# --- NemoClaw ---
# Settes automatisk av nemoclaw-start.sh – ikke endre manuelt
NEMOCLAW_SANDBOX_NAME=openclaw
